{
    "version": 10,
    "include": [
        "CMakeUserPresets-base.json"
    ],
    "configurePresets": [
        {
            "name": "kor_relwithdebinfo",
            "hidden": true,
            "inherits": [
                "lue_relwithdebinfo_configuration",
                "kor_relwithdebinfo_configuration"
            ]
        },
        {
            "name": "eejit_relwithdebinfo",
            "inherits": [
                "eejit_configuration",
                "kor_relwithdebinfo"
            ],
            "displayName": "eejit / relwithdebinfo"
        },
        {
            "name": "jureca_relwithdebinfo",
            "inherits": [
                "jureca_configuration",
                "kor_relwithdebinfo"
            ],
            "displayName": "jureca / relwithdebinfo"
        },
        {
            "name": "mammoth_relwithdebinfo",
            "inherits": [
                "mammoth_configuration",
                "kor_relwithdebinfo"
            ],
            "displayName": "mammoth / relwithdebinfo"
        },
        {
            "name": "mammoth_relwithdebinfo_sanitize",
            "inherits": [
                "mammoth_relwithdebinfo"
            ],
            "displayName": "mammoth / relwithdebinfo / sanitize",
            "cacheVariables": {
                // ASAN,  AddressSanitizer,           -fsanitize=address
                // LSAN,  LeakSanitizer,              -fsanitize=leak
                // MSAN,  MemorySanitizer,            -fsanitize=memory
                // TSAN,  ThreadSanitizer,            -fsanitize=thread
                // UBSAN, UndefinedBehaviorSanitizer, -fsanitize=undefined

                // https://clang.llvm.org/docs/LeakSanitizer.html

                // Invalid:
                // - ASAN AND (TSAN OR MSAN)
                // - LSAN AND (TSAN OR MSAN)
                // - LSAN AND MSAN

                // Set and override cache variables so the result is useful for sanitation
                // AddressSanitizer includes LeakSanitizer on Linux
                "CMAKE_C_FLAGS_INIT": "-fsanitize=address",
                "CMAKE_C_FLAGS_RELWITHDEBINFO_INIT": "-g",
                "CMAKE_CXX_FLAGS_INIT": "-fsanitize=address",
                "CMAKE_CXX_FLAGS_RELWITHDEBINFO_INIT": "-g",
                "CMAKE_EXE_LINKER_FLAGS_INIT": "-fsanitize=address",
                "CMAKE_SHARED_LINKER_FLAGS_INIT": "-fsanitize=address",
                "CMAKE_MODULE_LINKER_FLAGS_INIT": "-fsanitize=address",
                "CMAKE_EXE_LINKER_FLAGS_RELWITHDEBINFO_INIT": "",
                "CMAKE_MODULE_LINKER_FLAGS_RELWITHDEBINFO_INIT": "",
                "CMAKE_SHARED_LINKER_FLAGS_RELWITHDEBINFO_INIT": ""
            }
        },
        {
            "name": "velocity_relwithdebinfo",
            "inherits": [
                "velocity_configuration",
                "kor_relwithdebinfo"
            ],
            "displayName": "velocity / relwithdebinfo"
        }
    ]
}
